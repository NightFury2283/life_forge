      "type": "text",
      "x": 137.23171054316146,
      "y": 1613.9240762233703,
      "width": 768.3795776367188,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
