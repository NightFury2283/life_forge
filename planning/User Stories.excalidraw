      "updated": 1773911748860,
      "link": null,
      "locked": false,
      "text": "Пользователь открывает \nкалендарь",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Пользователь открывает \nкалендарь",
